generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  walletAddress String?   @unique
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  tokenBalance  TokenBalance?
  subscription  Subscription?
  usageLogs     UsageLog[]
  payments      Payment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TokenBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String
  status               String    @default("active")
  tokensPerMonth       Int
  startDate            DateTime  @default(now())
  endDate              DateTime?
  stripeSubscriptionId String?
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id         String   @id @default(cuid())
  userId     String
  tokensUsed Int
  model      String
  prompt     String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  currency    String
  method      String
  tokensAdded Int
  status      String   @default("pending")
  externalId  String?
  txHash      String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Node {
  id            String    @id @default(cuid())
  operatorEmail String    @unique
  walletAddress String?
  ollamaUrl     String
  name          String
  nodeType      String    @default("pc")       // pc | dgx_air
  status        String    @default("pending")  // pending | active | suspended
  approved      Boolean   @default(false)
  gpuModel      String?
  cpuModel      String?
  vramGb        Int?
  ramGb         Int?
  storageGb     Int?
  resources     String[]  // gpu | cpu | ram | storage | bandwidth | relay
  modelsLoaded  String[]
  tokensServed  Int       @default(0)
  agentToken    String?   @unique
  lastHeartbeat DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  earnings NodeEarning[]
}

model NodeEarning {
  id        String   @id @default(cuid())
  nodeId    String
  userId    String
  tokens    Int
  usdValue  Float
  createdAt DateTime @default(now())

  node Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model InferenceJob {
  id          String    @id @default(cuid())
  userId      String
  nodeId      String?
  messages    Json
  model       String    @default("llama3.2")
  status      String    @default("pending") // pending | processing | completed | failed
  result      String?
  tokensUsed  Int?
  createdAt   DateTime  @default(now())
  claimedAt   DateTime?
  completedAt DateTime?
}

model NodeApplication {
  id            String   @id @default(cuid())
  email         String   @unique
  walletAddress String?
  motivation    String?
  status        String   @default("pending")  // pending | approved | denied
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
