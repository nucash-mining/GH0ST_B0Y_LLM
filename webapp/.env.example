# Database
# Local dev (SQLite):
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"
# Production (Postgres — Neon / Vercel Postgres / Supabase):
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Ollama (local or remote node)
OLLAMA_URL="http://localhost:11434"
OLLAMA_DEFAULT_MODEL="llama3.2"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# Smart contract (Sepolia)
NEXT_PUBLIC_CHAIN_ID="11155111"
NEXT_PUBLIC_UNITY_TRUST_ADDRESS="0xa99e6418d06Cd2bE3cb5448CD85235C82f63839e"
PAYMENT_RECEIVER_ADDRESS="0x932951ccc368f3aF60f5A135c5f7e670f9DC1B31"

# Token pricing
TOKENS_PER_USD="100000"
ETH_PRICE_USD="3000"

# WATTx Compute Contracts (Sepolia)
# ComputeRegistry deployed at: 0x54b8c1c669bceb0574d0622b2cf4c18e6efb15b8
COMPUTE_REGISTRY_ADDRESS="0x54b8c1c669bceb0574d0622b2cf4c18e6efb15b8"
