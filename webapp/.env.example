# Oracle: signs on-chain job settlement transactions
# Private key of the oracle wallet (set oracle via ComputeRegistry.setOracle())
ORACLE_PRIVATE_KEY="0x..."
# Random secret shared between Vercel and internal settle calls
ORACLE_SECRET="generate-with: openssl rand -hex 32"

